rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isLegacyInsightAdmin() {
      return isSignedIn()
        && userDoc().role == 'admin'
        && userDoc().company == 'Insight Media Group LLC';
    }

    function isInsightOrg() {
      return isSignedIn()
        && userDoc().company == 'Insight Media Group LLC';
    }

    function hasPerm(field) {
      return isLegacyInsightAdmin()
        || (userDoc().permissions != null && userDoc().permissions[field] == true);
    }

    function canManageUsers() {
      return hasPerm('manageUsers');
    }

    function canSeeAllAgreements() {
      return canManageUsers() || isLegacyInsightAdmin();
    }

    function isPartyOnAgreement(data) {
      return isSignedIn()
        && data.accessKeys != null
        && (
          (
            request.auth.token.email != null
            && ('email:' + request.auth.token.email) in data.accessKeys
          )
          || (
            request.auth.token.email != null
            && ('email:' + request.auth.token.email.lower()) in data.accessKeys
          )
          || (
            userDoc().company != null
            && userDoc().company != ''
            && ('company:' + userDoc().company) in data.accessKeys
          )
        );
    }

    // Sign-only users may update signature fields without full editQuotes
    function canSignAgreement(data) {
      return hasPerm('signQuotes')
        && isPartyOnAgreement(data)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['signatures', 'initials', 'status', 'updatedAt']);
    }

    function canRecordPaymentTracking(data) {
      return isInsightOrg()
        && (hasPerm('exportPayments') || canManageUsers())
        && (canSeeAllAgreements() || isPartyOnAgreement(data))
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['paymentTracking', 'updatedAt']);
    }

    function canReadInsightSetup() {
      return isInsightOrg()
        && (
          hasPerm('manageClients')
          || hasPerm('manageCompanies')
          || hasPerm('manageCrew')
          || hasPerm('manageProjects')
          || hasPerm('createQuotes')
          || hasPerm('editQuotes')
          || hasPerm('loadDemoData')
          || hasPerm('useShotScout')
        );
    }

    function canEditAgreement(data) {
      return hasPerm('editQuotes')
        && (canSeeAllAgreements() || isPartyOnAgreement(data));
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || canManageUsers());
      allow create: if request.auth.uid == userId
        && request.resource.data.role == 'member'
        && request.resource.data.company == ''
        && request.resource.data.approved == false;
      allow update: if canManageUsers()
        || (
          request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['fcmTokens', 'notifyEmail', 'notifyPush', 'updatedAt'])
        );
      allow delete: if canManageUsers();
    }

    match /companies/{docId} {
      allow read: if canReadInsightSetup();
      allow create, update: if isInsightOrg() && hasPerm('manageCompanies');
      allow delete: if isInsightOrg() && hasPerm('manageCompanies');
    }

    match /clients/{docId} {
      allow read: if canReadInsightSetup();
      allow create, update: if isInsightOrg() && hasPerm('manageClients');
      allow delete: if isInsightOrg() && hasPerm('manageClients');
    }

    match /crewMembers/{docId} {
      allow read: if canReadInsightSetup();
      allow create, update: if isInsightOrg() && hasPerm('manageCrew');
      allow delete: if isInsightOrg() && hasPerm('manageCrew');
    }

    match /projects/{docId} {
      allow read: if canReadInsightSetup()
        || isProjectMember(docId)
        || isProjectOwner(docId);
      allow create: if isInsightOrg() && hasPerm('manageProjects');
      allow update: if isInsightOrg() && hasPerm('manageProjects');
      allow delete: if isInsightOrg() && hasPerm('manageProjects');

      match /members/{memberId} {
        allow read: if canManageProjectTeam(docId) || request.auth.uid == memberId;
        allow write: if false;
      }
    }

    match /servicePackages/{docId} {
      allow read: if hasPerm('createQuotes') || hasPerm('editQuotes') || canReadInsightSetup();
      allow create, update, delete: if isInsightOrg() && hasPerm('manageProjects');
    }

    match /equipmentCatalog/{docId} {
      allow read: if hasPerm('createQuotes') || hasPerm('editQuotes') || canReadInsightSetup();
      allow create, update, delete: if isInsightOrg() && hasPerm('manageProjects');
    }

    match /locationCatalog/{docId} {
      allow read: if hasPerm('createQuotes') || hasPerm('editQuotes') || canReadInsightSetup();
      allow create, update, delete: if isInsightOrg() && hasPerm('manageProjects');
    }

    match /agreements/{docId} {
      allow read: if canSeeAllAgreements() || isPartyOnAgreement(resource.data);
      allow create: if hasPerm('createQuotes');
      allow update: if canEditAgreement(resource.data)
        || canSignAgreement(resource.data)
        || canRecordPaymentTracking(resource.data);
      allow delete: if hasPerm('deleteQuotes')
        && (canSeeAllAgreements() || isPartyOnAgreement(resource.data));
    }

    match /templates/{docId} {
      allow read: if isInsightOrg()
        && (hasPerm('manageTemplates') || hasPerm('createQuotes') || hasPerm('editQuotes'));
      allow create, update: if isInsightOrg() && hasPerm('manageTemplates');
      allow delete: if isInsightOrg() && hasPerm('deleteTemplates');
    }

    function canReadNotification(data) {
      return isSignedIn() && (
        (data.userId != null && data.userId == request.auth.uid)
        || (
          data.companyRecipient != null
          && userDoc().company == data.companyRecipient
        )
      );
    }

    match /notifications/{docId} {
      allow read: if canReadNotification(resource.data);
      allow create: if isSignedIn()
        && request.resource.data.type == 'agreement_signed'
        && request.resource.data.read == false
        && request.resource.data.agreementId is string
        && request.resource.data.signerName is string
        && (
          request.resource.data.userId is string
          || request.resource.data.companyRecipient is string
        )
        && (hasPerm('signQuotes') || hasPerm('editQuotes') || hasPerm('createQuotes'));
      allow update: if canReadNotification(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'updatedAt']);
      allow delete: if false;
    }

    function canUseShotScout() {
      return isInsightOrg() && (
        hasPerm('useShotScout')
        || canManageUsers()
        || hasPerm('manageProjects')
      );
    }

    function isProjectMember(projectId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
    }

    function projectMemberData(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data;
    }

    function isProjectOwner(projectId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUserId == request.auth.uid;
    }

    function hasProjectArea(projectId, area) {
      return hasPerm('manageProjects')
        || canManageUsers()
        || isProjectOwner(projectId)
        || (
          isProjectMember(projectId)
          && projectMemberData(projectId).permissions[area] == true
        );
    }

    function canManageProjectTeam(projectId) {
      return hasPerm('manageProjects')
        || canManageUsers()
        || isProjectOwner(projectId);
    }

    function isScoutDirectMember(scoutId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/shotScoutProjects/$(scoutId)/members/$(request.auth.uid));
    }

    function canAccessScout(scoutId) {
      let scout = get(/databases/$(database)/documents/shotScoutProjects/$(scoutId)).data;
      return (isSignedIn() && scout.userId == request.auth.uid)
        || isScoutDirectMember(scoutId)
        || (
          scout.linkedProjectId != null
          && hasProjectArea(scout.linkedProjectId, 'scout')
        );
    }

    function canWriteScout(scoutId) {
      return canAccessScout(scoutId);
    }

    match /shotScoutProjects/{scoutId} {
      allow read: if canAccessScout(scoutId);
      allow create: if canUseShotScout()
        && request.resource.data.userId == request.auth.uid;
      allow update: if canWriteScout(scoutId);
      allow delete: if canUseShotScout()
        && resource.data.userId == request.auth.uid;

      match /images/{imageId} {
        allow read, write: if canWriteScout(scoutId);
      }

      match /analysis/{docId} {
        allow read, write: if canWriteScout(scoutId);
      }

      match /dpPlans/{docId} {
        allow read, write: if canWriteScout(scoutId);
      }

      match /shotLists/{docId} {
        allow read, write: if canWriteScout(scoutId);
      }

      match /previews/{docId} {
        allow read, write: if canWriteScout(scoutId);
      }

      match /members/{memberId} {
        allow read: if canWriteScout(scoutId) || request.auth.uid == memberId;
        allow write: if false;
      }
    }

    match /users/{userId}/gearProfiles/{gearId} {
      allow read, write: if request.auth.uid == userId && canUseShotScout();
    }

    match /users/{userId}/gearList/{docId} {
      allow read, write: if request.auth.uid == userId && canUseShotScout();
    }

    match /users/{userId}/lightFixtures/{fixtureId} {
      allow read, write: if request.auth.uid == userId && canUseShotScout();
    }

    match /users/{userId}/lightingRecipes/{recipeId} {
      allow read, write: if request.auth.uid == userId && canUseShotScout();
    }

    function canUseProductionBoard() {
      return isInsightOrg()
        && (canUseShotScout() || hasPerm('manageProjects'));
    }

    match /productionBoards/{boardId} {
      allow read: if canReadInsightSetup()
        || canUseProductionBoard()
        || (
          resource.data.projectId != null
          && (
            hasProjectArea(resource.data.projectId, 'production')
            || hasProjectArea(resource.data.projectId, 'shots')
          )
        );
      allow create: if canUseProductionBoard()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.projectId is string;
      allow update: if canUseProductionBoard()
        || (
          resource.data.projectId != null
          && (
            hasProjectArea(resource.data.projectId, 'production')
            || hasProjectArea(resource.data.projectId, 'shots')
          )
        );
      allow delete: if canUseProductionBoard()
        && (resource.data.userId == request.auth.uid || hasPerm('manageProjects'));
    }

    match /referenceGuide/{docId} {
      allow read: if canUseShotScout() || hasPerm('manageProjects');
      allow write: if false;
    }

    match /stageBoards/{boardId} {
      allow read: if canReadInsightSetup()
        || canUseProductionBoard()
        || (
          resource.data.projectId != null
          && (
            hasProjectArea(resource.data.projectId, 'production')
            || hasProjectArea(resource.data.projectId, 'shots')
          )
        )
        || (
          resource.data.projectId == null
          && resource.data.userId == request.auth.uid
        );
      allow create: if request.resource.data.userId == request.auth.uid
        && (
          (
            request.resource.data.projectId == null
            && canUseProductionBoard()
          )
          || (
            request.resource.data.projectId is string
            && (
              canUseProductionBoard()
              || hasProjectArea(request.resource.data.projectId, 'production')
              || hasProjectArea(request.resource.data.projectId, 'shots')
            )
          )
        );
      allow update: if canUseProductionBoard()
        || (
          resource.data.projectId != null
          && (
            hasProjectArea(resource.data.projectId, 'production')
            || hasProjectArea(resource.data.projectId, 'shots')
          )
        )
        || (
          resource.data.projectId == null
          && resource.data.userId == request.auth.uid
        );
      allow delete: if canUseProductionBoard()
        && (resource.data.userId == request.auth.uid || hasPerm('manageProjects'));
    }

    match /scriptWriterSessions/{sessionId} {
      allow read, write: if false;

      match /members/{memberId} {
        allow read: if request.auth.uid == memberId;
        allow write: if false;
      }
    }

    // Weekly script trend snapshots — server-only (Admin SDK + cron)
    match /trendSnapshots/{contentType} {
      allow read, write: if false;
    }

    // AI usage aggregates — server-only (Admin SDK)
    match /aiUsageMonthly/{monthKey} {
      allow read, write: if false;
    }

    // Client signing links — server-only (Firebase Admin SDK)
    match /signingLinks/{docId} {
      allow read, write: if false;
    }
  }
}
