# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Web push — Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# App URL for email links (production: https://shootspine.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin (server) — JSON string OR individual fields from service account
# Vercel: paste FIREBASE_SERVICE_ACCOUNT_JSON as ONE line (no line breaks). Keep \n inside private_key.
FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY=

# Gemini — CineScout AI (Shot Scout): vision analysis + planning
# Create key: https://aistudio.google.com/apikey
# PRODUCTION (insight-deal-builder on Vercel):
#   1. Enable API: https://console.cloud.google.com/apis/library/generativelanguage.googleapis.com?project=insight-deal-builder
#   2. API key → Application restrictions: None (server-side calls from Vercel)
#   3. API key → API restrictions: Generative Language API only
#   4. Add GEMINI_API_KEY + SCOUT_USE_MOCK_AI=false in Vercel env
#   5. Verify: GET /api/health/scout-ai on your deployed URL
GEMINI_API_KEY=
GEMINI_SCOUT_MODEL=gemini-2.5-flash

# OpenAI — optional; skip when using Vertex for images (cheaper)
OPENAI_API_KEY=
SCOUT_IMAGE_MODEL=gpt-image-1

# Image generation: vertex (cheapest, uses service account) | openai | auto
SCOUT_IMAGE_PROVIDER=vertex
# 0 = diagram only | 3 = default overall scene views (master / medium / mood) | all = one per shot (expensive)
SCOUT_MAX_CINEMATIC_PREVIS=3
SCOUT_IMAGE_QUALITY=medium
# Downscale Vertex output (~1024px) before upload — saves storage; API cost unchanged
SCOUT_IMAGE_MAX_WIDTH=512
SCOUT_IMAGE_JPEG_QUALITY=75

# Gemini image model on Vertex / AI Studio
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Set false when GEMINI_API_KEY and/or FIREBASE_SERVICE_ACCOUNT_JSON (Vertex) is set
SCOUT_USE_MOCK_AI=true

# Quote scope assistant (New Agreement wizard) uses the same Gemini/Vertex stack as Shot Scout — no extra keys.

# Tavily — web research for Script writer trends & Scout technique lookup (server-only)
# Gemini synthesizes Tavily results; Tavily performs the actual web search.
# Reuse the same key for weekly topic crawls in your other apps.
TAVILY_API_KEY=

# Weekly trend snapshot cron (Vercel Cron → /api/cron/trend-snapshots, Mondays 14:00 UTC)
# Vercel sends Authorization: Bearer <CRON_SECRET> when this env var is set.
CRON_SECRET=

# Optional dedicated secret for /api/health/firebase and /api/health/email uptime checks.
# Falls back to CRON_SECRET when unset. Send as Authorization: Bearer … or x-health-secret header.
HEALTH_CHECK_SECRET=

# Vertex AI fallback when API key is blocked (uses FIREBASE_SERVICE_ACCOUNT_JSON)
# auto = try API key first, fall back to Vertex on 403 | true = Vertex only | false = API key only
SCOUT_GEMINI_USE_VERTEX=auto
VERTEX_AI_LOCATION=us-central1
VERTEX_GEMINI_MODEL=gemini-2.5-flash
VERTEX_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Enable: https://console.cloud.google.com/apis/library/aiplatform.googleapis.com?project=insight-deal-builder
# IAM: grant firebase-adminsdk-...@insight-deal-builder.iam.gserviceaccount.com → Vertex AI User
# https://console.cloud.google.com/iam-admin/iam?project=insight-deal-builder
# Single line only: re_… (no "Bearer " prefix, no line breaks)
RESEND_API_KEY=
RESEND_FROM_EMAIL=ShootSpine <notifications@shootspine.com>

# Stripe — client deposit/balance payments on signed agreements
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from Stripe CLI (`stripe listen`) or Dashboard → Webhooks
# Endpoint: POST https://your-domain.com/api/webhooks/stripe
# Events: checkout.session.completed
STRIPE_WEBHOOK_SECRET=

# Revenue & Opportunities (second product — default OFF)
# Set true to show navigation and enable /api/revenue routes
# REVENUE_OPPORTUNITIES_ENABLED=true
# Weekly idea engine in sidebar (default OFF — use Script writer for concepts)
# NEXT_PUBLIC_CONTENT_IDEAS_NAV=true
# N8N_BASE_URL=
# N8N_API_KEY=
# N8N_WEBHOOK_SECRET=
# REVENUE_N8N_MOCK=true
# REVENUE_CRON_ORGANIZATION_COMPANY=Insight Media Group LLC
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/revenue/gmail/callback
