rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function userData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isLegacyInsightAdmin() {
      return userData().role == 'admin'
        && userData().company == 'Insight Media Group LLC';
    }

    function hasPerm(field) {
      return isLegacyInsightAdmin()
        || (userData().permissions != null && userData().permissions[field] == true);
    }

    function canManageUsers() {
      return hasPerm('manageUsers');
    }

    function isProjectOwner(projectId) {
      return firestore.get(/databases/(default)/documents/projects/$(projectId)).data.ownerUserId
        == request.auth.uid;
    }

    function isProjectMember(projectId) {
      return firestore.exists(
        /databases/(default)/documents/projects/$(projectId)/members/$(request.auth.uid)
      );
    }

    function projectMemberData(projectId) {
      return firestore.get(
        /databases/(default)/documents/projects/$(projectId)/members/$(request.auth.uid)
      ).data;
    }

    function hasProjectArea(projectId, area) {
      return hasPerm('manageProjects')
        || canManageUsers()
        || isProjectOwner(projectId)
        || (
          isProjectMember(projectId)
          && projectMemberData(projectId).permissions[area] == true
        );
    }

    function canAccessProductionStorage(projectId) {
      return hasProjectArea(projectId, 'production')
        || hasProjectArea(projectId, 'shots');
    }

    // Identity verification images — server-only via Admin SDK signed URLs
    match /identity-verification/{allPaths=**} {
      allow read, write: if false;
    }

    match /w9-documents/{allPaths=**} {
      allow read, write: if false;
    }

    match /shot-scout/{userId}/{scoutProjectId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /production/{projectId}/{allPaths=**} {
      allow read: if request.auth != null && canAccessProductionStorage(projectId);
      allow write: if request.auth != null
        && canAccessProductionStorage(projectId)
        && request.resource.size < 25 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'text/plain'
          || request.resource.contentType == 'application/msword'
          || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
        );
    }

    match /script-writer/{userId}/{sessionId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (
          (request.resource.size < 10 * 1024 * 1024
            && request.resource.contentType.matches('image/.*'))
          || (request.resource.size < 50 * 1024 * 1024
            && request.resource.contentType.matches('video/.*'))
        );
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
